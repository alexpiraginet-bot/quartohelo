# Quarto da Helô — variáveis de ambiente
# Enquanto estas variáveis não existirem, o site e o guia rodam sobre a
# estrutura semente (src/data/seed.ts). Ao preencher, o painel e o guia
# passam a ler e gravar no Supabase, sem trocar nada no código.

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (somente no servidor — nunca expor no cliente).
# Usada pelo painel e pela jornada de cada cliente.
SUPABASE_SERVICE_ROLE_KEY=
