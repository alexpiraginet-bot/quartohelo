# Quarto da Helô — variáveis de ambiente
# O banco JÁ está ligado: a URL e a chave pública (anon) têm padrão embutido no
# código (são públicas por design; o RLS protege os dados), então a leitura do
# site e do guia funciona sem configurar nada. Estas envs só existem para
# sobrescrever (ex.: apontar para outro ambiente) ou para habilitar a ESCRITA.

# Supabase — Project Settings > API (opcionais; sobrescrevem o padrão do código)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço (somente no servidor — nunca expor no cliente nem no repo).
# NECESSÁRIA para a fase de escrita: edição pelo painel, upload de fotos,
# jornada por cliente e coleta de analytics.
# Definir na Vercel > Settings > Environment Variables quando ligarmos o admin.
SUPABASE_SERVICE_ROLE_KEY=

# Senha do painel da Helô (/admin). Sem ela o painel abre só em visualização e
# NADA pode ser gravado. Escolher uma senha forte e definir na Vercel.
QH_ADMIN_SENHA=
